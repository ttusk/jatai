---
interface Props {
  as?: "h1" | "span";
  animated?: boolean;
  class?: string;
}

const { as: Tag = "span", animated = false, class: className = "" } = Astro.props;
const letters = ["J", "A", "T", "A", "Í"];
---

<Tag
  class:list={["pixel-wordmark", { "pixel-wordmark--animated": animated }, className]}
  aria-label="Jataí"
  tabindex={animated ? "0" : undefined}
>
  {letters.map((letter, index) => (
    <span aria-hidden="true" style={`--letter-index: ${index}`}>{letter}</span>
  ))}
</Tag>
