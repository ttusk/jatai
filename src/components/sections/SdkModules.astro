---
const modules = [
  ["jatai.accounts", "Contas e saldos simulados", "accounts.list()"],
  ["jatai.auth", "Consentimento e tokens", "auth.createConsent()"],
  ["jatai.payments", "Pix e callbacks", "payments.createPix()"],
  ["jatai.telemetry", "Latência e erros", "telemetry.inject()"],
  ["jatai.data", "Dados sintéticos", "data.generate()"],
];
---

<section id="sdk" class="scroll-mt-24 border-t border-line py-24 sm:py-32">
  <div class="mx-auto w-full max-w-6xl px-6 lg:px-10">
    <p class="font-mono text-xs uppercase tracking-[0.18em] text-ink/40">API</p>
    <h2 class="mt-4 text-3xl font-medium tracking-[-0.04em] text-ink sm:text-5xl">
      Cinco módulos, um pacote.
    </h2>

    <div class="mt-14 border-t border-line">
      {modules.map(([namespace, purpose, example]) => (
        <div
          tabindex="0"
          class="group grid gap-2 border-b border-line py-6 outline-none transition-colors hover:bg-honey/10 focus-visible:bg-honey/10 sm:grid-cols-[1fr_1.25fr_1fr] sm:items-center sm:gap-8"
        >
          <code class="font-mono text-sm font-medium text-ink">{namespace}</code>
          <p class="text-sm text-ink/55">{purpose}</p>
          <code class="font-mono text-xs text-ink/40 transition-colors group-hover:text-ink group-focus-visible:text-ink sm:text-right">
            {example}
          </code>
        </div>
      ))}
    </div>

    <a
      class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-ink underline decoration-honey-dark decoration-2 underline-offset-4 transition-colors hover:text-honey-dark focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-honey-dark"
      href="#playground"
    >
      Executar exemplo <span aria-hidden="true">↑</span>
    </a>
  </div>
</section>
