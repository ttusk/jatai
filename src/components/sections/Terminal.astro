---
const code = `import { jatai } from "@jatai/sdk";

const consents = await jatai.openFinance.listConsents({
  participantId: "12345678",
  status: "AUTHORISED"
});

console.log(consents[0].permissions);
// ["ACCOUNTS_READ", "CREDIT_CARDS_READ", "RESOURCES_READ"]`;
---

<section class="px-4 py-16 sm:px-6 sm:py-24">
  <div class="mx-auto max-w-4xl">
    <p class="text-sm font-medium uppercase tracking-widest text-primary">
      How it works
    </p>
    <div class="mt-6 overflow-hidden rounded-xl border bg-card shadow-sm">
      <div class="flex items-center justify-between border-b bg-muted px-4 py-3">
        <span class="text-xs font-medium text-muted-foreground font-mono">
          example.ts
        </span>
        <span class="text-xs text-muted-foreground">Jataí SDK</span>
      </div>
      <pre
        class="overflow-x-auto p-4 text-sm leading-relaxed sm:p-6 sm:text-base"><code class="font-mono text-foreground">{code}</code></pre>
    </div>
  </div>
</section>
