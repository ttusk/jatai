---
import { ProductShowcase } from "@/components/first-flight/ProductShowcase";
import Footer from "@/components/sections/Footer.astro";
import Hero from "@/components/sections/Hero.astro";
import Navbar from "@/components/sections/Navbar.astro";
import { SdkModules } from "@/components/sections/SdkModules";
import Layout from "@/layouts/Layout.astro";
---

<Layout>
  <Navbar />
  <main id="conteudo">
    <Hero />

    <section id="playground" class="scroll-mt-24 border-t border-line py-24 sm:py-32">
      <div class="mx-auto w-full max-w-6xl px-6 lg:px-10">
        <div class="mb-14 max-w-2xl sm:mb-20">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-ink/40">Playground</p>
          <h2 class="mt-4 text-3xl font-medium tracking-[-0.04em] text-ink sm:text-5xl">
            Veja o SDK em uso.
          </h2>
          <p class="mt-5 max-w-lg text-base leading-7 text-ink/55">
            Role para acompanhar uma integração simulada, do pacote ao callback.
          </p>
        </div>

        <ProductShowcase client:visible />
      </div>
    </section>

    <SdkModules />
  </main>
  <Footer />
</Layout>
