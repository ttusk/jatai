---
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Jataí — SDK educacional de Open Finance",
  description = "SDK educacional fictício para testar consentimento, contas e Pix sem dados reais.",
} = Astro.props;
---

<html lang="pt-BR" class="scroll-smooth bg-white motion-reduce:scroll-auto">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-w-80 overflow-x-hidden bg-white font-sans text-ink antialiased selection:bg-honey selection:text-ink">
    <a
      class="fixed left-4 top-4 z-[100] -translate-y-24 rounded-full bg-ink px-4 py-2 text-sm text-white transition-transform focus:translate-y-0"
      href="#conteudo"
    >Pular para o conteúdo</a>
    <slot />
  </body>
</html>
